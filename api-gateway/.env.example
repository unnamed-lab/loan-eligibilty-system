# API gateway
PORT=3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=3600s

# PostgreSQL (Prisma reads DATABASE_URL)
DATABASE_URL=postgresql://loan:loan@localhost:5432/loan_eligibility?schema=public

# Downstream services
INFERENCE_URL=http://localhost:8081
SHAP_URL=http://localhost:8000

# Feature contract location (defaults to ../../shared/feature-contract.json)
# FEATURE_CONTRACT_PATH=/shared/feature-contract.json
